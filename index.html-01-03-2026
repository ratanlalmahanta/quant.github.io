<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Ratanlal Mahanta — Senior Quant Dashboard</title>

<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">

<style>
:root{
 --bg:#F4F1EA;
 --primary:#D16D54;
 --secondary:#3D5A80;
 --accent:#E8C547;
 --text:#2D2A26;
}
body{
 font-family:'Lato',sans-serif;
 background:var(--bg);
 color:var(--text);
}
h1,h2,h3{font-family:'Merriweather',serif;}
.card-shadow{box-shadow:0 4px 6px rgba(0,0,0,.1);}
.chart-container{position:relative;width:100%;height:320px;}
</style>
</head>

<body>

<!-- NAV -->
<nav class="bg-white shadow-sm sticky top-0 z-50">
<div class="max-w-7xl mx-auto px-4 h-16 flex justify-between items-center">
<div class="flex items-center">
<span class="text-2xl font-bold text-[#D16D54]">RM</span>
<span class="ml-2 font-medium">Senior Quant Dashboard</span>
</div>
<div class="flex space-x-4 text-sm">
<button onclick="scrollToSection('hero')">Overview</button>
<button onclick="scrollToSection('analytics')">Analytics</button>
<button onclick="scrollToSection('hft')">HFT</button>
<button onclick="scrollToSection('strategy')">Strategy</button>
</div>
</div>
</nav>

<!-- HERO -->
<section id="hero" class="bg-white border-b">
<div class="max-w-7xl mx-auto px-6 py-16">
<h1 class="text-4xl font-bold mb-3">
Ratanlal Mahanta
</h1>
<p class="text-lg text-gray-600">
Quantitative Research • Model Validation • Algorithmic Trading • AI Finance
</p>
</div>
</section>

<!-- ================= QUANT ANALYTICS ================= -->
<section id="analytics" class="max-w-7xl mx-auto px-6 py-14">

<div class="border-l-4 border-[#3D5A80] pl-4 mb-8">
<h2 class="text-3xl font-bold">Quant Analytics Snapshot</h2>
</div>

<div class="bg-white rounded-xl p-8 card-shadow">
<div class="grid md:grid-cols-2 gap-8">

<div>
<h3 class="text-center font-bold mb-3">Domain Distribution</h3>
<div class="chart-container"><canvas id="domainChart"></canvas></div>
</div>

<div>
<h3 class="text-center font-bold mb-3">Model Growth</h3>
<div class="chart-container"><canvas id="growthChart"></canvas></div>
</div>

</div>
</div>

</section>

<!-- ================= HFT ANALYTICS ================= -->
<section id="hft" class="max-w-7xl mx-auto px-6 py-14">

<div class="border-l-4 border-[#D16D54] pl-4 mb-8">
<h2 class="text-3xl font-bold">HFT & Quant Trading Analytics</h2>
</div>

<div class="bg-white rounded-xl p-8 card-shadow">

<div class="grid md:grid-cols-2 gap-8">

<div>
<h3 class="text-center font-bold mb-3">Strategy Performance (PnL)</h3>
<div class="chart-container"><canvas id="hftPerformanceChart"></canvas></div>
</div>

<div>
<h3 class="text-center font-bold mb-3">Execution Latency</h3>
<div class="chart-container"><canvas id="latencyChart"></canvas></div>
</div>

</div>

</div>

</section>

<!-- ================= STRATEGY DISTRIBUTION ================= -->
<section id="strategy" class="max-w-7xl mx-auto px-6 py-14">

<div class="border-l-4 border-[#3D5A80] pl-4 mb-8">
<h2 class="text-3xl font-bold">Strategy Distribution Analytics</h2>
</div>

<div class="bg-white rounded-xl p-8 card-shadow">

<div class="grid md:grid-cols-2 gap-8">

<div>
<h3 class="text-center font-bold mb-3">Strategy Allocation</h3>
<div class="chart-container"><canvas id="strategyChart"></canvas></div>
</div>

<div>
<h3 class="text-center font-bold mb-3">Risk Contribution</h3>
<div class="chart-container"><canvas id="riskStrategyChart"></canvas></div>
</div>

</div>

</div>
</section>

<footer class="bg-[#2D2A26] text-white text-center py-10 mt-20">
<h2 class="text-xl">Ratanlal Mahanta — Senior Quant</h2>
</footer>

<script>

function scrollToSection(id){
 document.getElementById(id).scrollIntoView({behavior:'smooth'});
}

/* DOMAIN */
new Chart(domainChart,{
type:'doughnut',
data:{
labels:['FRTB','IRRBB','CVA','Derivatives','AI'],
datasets:[{
data:[25,20,20,25,10],
backgroundColor:['#3D5A80','#D16D54','#E8C547','#5E8C61','#2D2A26']
}]
}
});

/* MODEL GROWTH */
new Chart(growthChart,{
type:'bar',
data:{
labels:['2019','2020','2021','2022','2023','2024','2025'],
datasets:[{
label:'Models Delivered',
data:[4,6,7,9,11,13,16],
backgroundColor:'#D16D54'
}]
}
});

/* HFT PERFORMANCE */
new Chart(hftPerformanceChart,{
type:'line',
data:{
labels:['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug'],
datasets:[{
label:'PnL Curve',
data:[0,2,4,6,9,11,15,18],
borderColor:'#D16D54',
backgroundColor:'rgba(209,109,84,.2)',
fill:true
}]
}
});

/* LATENCY */
new Chart(latencyChart,{
type:'bar',
data:{
labels:['<5ms','5-10ms','10-15ms','15-20ms','20ms+'],
datasets:[{
label:'Orders %',
data:[18,35,28,12,7],
backgroundColor:'#3D5A80'
}]
}
});

/* STRATEGY DISTRIBUTION */
new Chart(strategyChart,{
type:'doughnut',
data:{
labels:[
'HFT Market Making',
'Stat Arb',
'Vol Arb',
'Momentum',
'Mean Reversion',
'AI Signals'
],
datasets:[{
data:[34,22,18,10,8,8],
backgroundColor:[
'#D16D54','#3D5A80','#E8C547',
'#5E8C61','#2D2A26','#7A5AF8'
]
}]
}
});

/* RISK CONTRIBUTION */
new Chart(riskStrategyChart,{
type:'bar',
data:{
labels:['HFT','Stat-Arb','Vol-Arb','Momentum','Mean Rev','AI'],
datasets:[{
label:'Risk Contribution %',
data:[28,24,20,12,8,8],
backgroundColor:'#3D5A80'
}]
}
});

</script>

</body>
</html>
